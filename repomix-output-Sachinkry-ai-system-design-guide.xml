# Using OpenAI Moderation API
def check_with_openai(text: str) -> GuardrailResult:
    response = openai.Moderation.create(input=text)
    result = response["results"][0]

    if result["flagged"]:
        categories = [k for k, v in result["categories"].items() if v]
